# Required
OPENAI_API_KEY=sk-...

# Optional: Tavily for web search (free tier: https://tavily.com)
TAVILY_API_KEY=tvly-...

# Optional: Three-tier LLM config (GPT-5.4 family defaults)
PLANEX_FAST_MODEL=gpt-5.4-nano
PLANEX_SMART_MODEL=gpt-5.4-mini
PLANEX_STRATEGIC_MODEL=gpt-5.4-mini
PLANEX_EMBEDDING_MODEL=text-embedding-3-small

# Premium: upgrade SMART/STRATEGIC for better quality
# PLANEX_SMART_MODEL=gpt-5.4         # $2.50/1M in, best quality
# PLANEX_STRATEGIC_MODEL=gpt-5.4     # best planning
# PLANEX_STRATEGIC_MODEL=gpt-5.4-pro # $30/1M in, maximum reasoning
